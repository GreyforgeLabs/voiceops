{
  "name": "voiceops",
  "version": "0.1.0",
  "description": "VoiceOps: Full-duplex Discord voice pipeline for agent gateways",
  "author": "Greyforge Labs (https://greyforge.tech)",
  "homepage": "https://greyforge.tech/chronicles/voiceops-integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreyforgeLabs/voiceops.git"
  },
  "bugs": {
    "url": "https://github.com/GreyforgeLabs/voiceops/issues"
  },
  "keywords": [
    "discord", "voice", "tts", "asr", "whisper", "kokoro",
    "full-duplex", "agent-gateway", "voice-bot", "discord-bot"
  ],
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "start": "node index.mjs",
    "dev": "node --watch index.mjs",
    "test": "find . -name '*.mjs' -not -path './node_modules/*' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "discord.js": "14.26.4",
    "kokoro-js": "1.2.1",
    "opusscript": "0.0.8",
    "prism-media": "1.3.5",
    "ws": "8.20.0"
  },
  "overrides": {
    "brace-expansion": "1.1.13",
    "lodash": "4.18.1",
    "protobufjs": "7.5.5",
    "tar": "7.5.13",
    "undici": "6.24.1"
  },
  "notes": {
    "@ricky0123/vad-node": "Benchmarked (43ms cold-start, 0.42ms/chunk). NOT a runtime dep - pipeline uses AfterSilence+RMS gate. Conflicts with kokoro-js ONNX version. Add back if Silero VAD needed in Phase 4."
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
